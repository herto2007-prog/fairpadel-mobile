{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fairpadel",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fairpadel.app"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#df2531"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Fairpadel necesita acceso a tus fotos para subir tu avatar."
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0E14",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.fairpadel.app",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "f6610fe0-8584-45df-8925-63fb52354545"
      }
    },
    "owner": "fairpadel"
  }
}
