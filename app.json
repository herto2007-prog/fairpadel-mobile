{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fairpadel",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fairpadel.app"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#df2531"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Fairpadel necesita acceso a tus fotos para subir tu avatar."
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0E14",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.fairpadel.app",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.VIBRATE"
      ]
    },

    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
